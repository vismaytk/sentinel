# SENTINEL - Vehicle Intelligence Platform
# .gitignore

# ═══════════════════════════════════════════════════════════
# Python
# ═══════════════════════════════════════════════════════════
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
venv/
ENV/
env/
.venv/

# ═══════════════════════════════════════════════════════════
# IDE / Editor
# ═══════════════════════════════════════════════════════════
.idea/
.vscode/
*.swp
*.swo
*~
.project
.pydevproject
.settings/
*.sublime-project
*.sublime-workspace

# ═══════════════════════════════════════════════════════════
# Database
# ═══════════════════════════════════════════════════════════
data/snapshots/*.json
data/*.db
data/*.db-journal
data/*.db-wal
data/*.db-shm
*.sqlite3

# ═══════════════════════════════════════════════════════════
# Logs
# ═══════════════════════════════════════════════════════════
logs/*.log
*.log

# ═══════════════════════════════════════════════════════════
# Models (large binary files - download separately)
# ═══════════════════════════════════════════════════════════
models/*.pt
models/*.onnx
models/*.engine
!models/.gitkeep

# ═══════════════════════════════════════════════════════════
# Media files (test videos/images)
# ═══════════════════════════════════════════════════════════
*.mp4
*.mov
*.avi
*.mkv
*.jpg
*.jpeg
*.png
*.gif
*.bmp
*.json
!static/**/*.png
!static/**/*.jpg

# ═══════════════════════════════════════════════════════════
# Jupyter Notebooks
# ═══════════════════════════════════════════════════════════
.ipynb_checkpoints/
*.ipynb

# ═══════════════════════════════════════════════════════════
# OS generated
# ═══════════════════════════════════════════════════════════
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ═══════════════════════════════════════════════════════════
# Misc
# ═══════════════════════════════════════════════════════════
.env
.env.local
*.bak
*.tmp
*.temp
